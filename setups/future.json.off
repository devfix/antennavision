    },
    {
      "id": "ref_rx_stop",
      "origin": "",
      "translation": {
        "x": 1,
        "y": 1,
        "z": 0
      },
      "rotation": {
        "yaw": 0.0,
        "pitch": 0.0,
        "roll": 0.0
      }
    }
  ],
  "sources": [
    {
      "id": "source_1",
      "type": "SignalSource",
      "power_dbm": 10.0
    }
  ],
  "radiators": [
    {
      "id": "transmitter",
      "reference": "",
      "type": "HertzianDipole",
      "length": 1e-3
    },
    {
      "id": "receiver",
      "reference": "ref_rx_start",
      "type": "HertzianDipole",
      "length": 1e-3
    },
    {
      "id": "radiator_2",
      "reference": "",
      "type": "CustomRadiator",
      "effective_length": [
        "0",
        "cos(pi/2*cos(theta))/sin(theta+1e-12)",
        "sin(phi/2)^3"
      ]
    }
  ],
  "connections": [
    {
      "from": "source_1#0",
      "to": "radiator_1#0"
    }
  ],
  "tasks": [
    {
      "type": "plot_directivity_over_theta",
      "radiator": "transmitter",
      "phis": [0.0, 1.0]
    },
    {
      "type": "plot_directivity_over_theta",
      "radiator": "receiver",
      "phis": [0.0, 0.5, 1.0]
    },
    {
      "type": "plot_gain_over_straight",
      "source": "transmitter",
      "sink": "receiver",
      "ref_start": "ref_rx_start",
      "ref_stop": "ref_rx_stop",
      "wavelength": 0.1,
      "distance_axis": "x"
    }
  ]
